# Azure and project configuration
location     = "East US"
project_name = "rancher"
environment  = "dev"

# AKS configuration
node_count     = 1
max_node_count = 2
node_vm_size   = "Standard_B2s"  # Cost-optimized: 2 vCPU, 4 GB RAM

# Rancher configuration
rancher_bootstrap_password = "RancherPassword123!"  # Change this to a secure password

# Let's Encrypt configuration
letsencrypt_email = "your-email@example.com"  # Change this to your email address